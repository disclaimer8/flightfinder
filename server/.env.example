# ─────────────────────────────────────────────────
# server/.env.example
# Copy to server/.env and fill in real values locally.
# Production secrets are injected by .github/workflows/deploy.yml.
# ─────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=5001
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-characters

# Mail (Mailgun sandbox for dev)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAIL_FROM="himaxym <no-reply@himaxym.com>"

# Data sources
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
AIRLABS_API_KEY=
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=
TRAVELPAYOUTS_TRS=
RAPIDAPI_KEY=
ADSBLOL_ENABLED=0

# Observability
SENTRY_DSN=

# Stripe — required for /api/subscriptions/*.
# Set STRIPE_LIVE=0 to keep endpoints in 503 "unavailable" state.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx
STRIPE_PRICE_LIFETIME=price_xxx
STRIPE_LIVE=0

# Public origin used for Checkout session success/cancel URLs
PUBLIC_WEB_ORIGIN=https://himaxym.com

# Ingestion (Plan 2)
INGEST_ENABLED=0           # 1 = delayIngestionWorker runs every 6h
INGEST_TOP_ROUTES=30       # how many top routes to sample per cycle
FLEET_BOOTSTRAP=0          # 1 = one-shot Mictronics fleet bootstrap after 10s
OPENWEATHER_API_KEY=       # free tier key from openweathermap.org

# Admin
ADMIN_TOKEN=               # random 64-hex string; enables /api/auth/admin/* endpoints
