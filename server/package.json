    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
