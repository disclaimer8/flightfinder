{
  "name": "flight-search-api",
  "version": "1.0.0",
  "description": "Flight search API with airplane type filters",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "clearMocks": true,
    "setupFiles": [
      "<rootDir>/src/__tests__/setup.js"
    ]
  },
  "keywords": [
    "flight",
    "search",
    "airplane"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "amadeus": "^11.0.0",
    "argon2": "^0.44.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mailgun.js": "^12.7.1",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
