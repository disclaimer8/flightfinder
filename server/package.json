{
  "name": "flight-search-api",
  "version": "1.0.0",
  "description": "Flight search API with airplane type filters",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "clearMocks": true,
    "setupFiles": [
      "<rootDir>/src/__tests__/setup.js"
    ]
  },
  "keywords": [
    "flight",
    "search",
    "airplane"
  ],
  "author": "",
  "license": "MIT",
  "overrides": {
    "fast-xml-parser": "^5.7.0"
  },
  "dependencies": {
    "@sentry/node": "^10.49.0",
    "adm-zip": "^0.5.17",
    "amadeus": "^11.0.0",
    "argon2": "^0.44.0",
    "axios": "^1.15.1",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "duckdb": "^1.4.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mailgun.js": "^13.0.0",
    "node-cache": "^5.1.2",
    "stripe": "^22.0.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@dsnp/parquetjs": "^1.8.7",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
